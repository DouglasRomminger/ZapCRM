# Supabase
DATABASE_URL=               # postgres://... (connection pooling)
DIRECT_URL=                 # postgres://... (direto — Prisma migrations)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=  # apenas backend, NUNCA expor no frontend

# Auth
JWT_SECRET=                 # openssl rand -base64 32
NEXTAUTH_SECRET=            # openssl rand -base64 32
NEXTAUTH_URL=               # https://app.zapcrmapp.com.br

# Evolution API
EVOLUTION_API_URL=          # https://evolution-evolution-api.n9d007.easypanel.host
EVOLUTION_API_KEY=          # chave global do painel Evolution API

# Pagar.me
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=

# Redis
REDIS_URL=                  # redis://localhost:6379

# App
API_PORT=                   # ex: 3001
APP_URL=                    # https://app.zapcrmapp.com.br
ADMIN_URL=                  # https://admin.zapcrmapp.com.br
NODE_ENV=                   # development | production

# Dev helpers (remover em produção)
NEXT_PUBLIC_API_URL=        # http://localhost:3001
NEXT_PUBLIC_DEV_EMPRESA_ID= # empresaId para testes sem auth
